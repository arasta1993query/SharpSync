<Project>
  <Target Name="SharpSyncCodeGeneration" AfterTargets="Build">
    <Message Importance="High" Text="[SharpSync] Triggering Code Generation for $(ProjectName)..." />
    <Exec Command="dotnet sharpsync &quot;$(TargetPath)&quot; &quot;$(ProjectDir)SharpSyncGenerated/api.ts&quot;" ContinueOnError="true" />
  </Target>
</Project>
