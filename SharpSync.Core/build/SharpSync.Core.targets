<Project>
  <Target Name="SharpSyncCodeGeneration" AfterTargets="Build">
    <Message Importance="High" Text="[SharpSync] Triggering Code Generation for $(ProjectName)..." />
    <Exec Command="dotnet sharpsync &quot;$(TargetPath)&quot; --output &quot;$(ProjectDir)SharpSyncGenerated&quot; --client axios" ContinueOnError="true" />
  </Target>
</Project>
